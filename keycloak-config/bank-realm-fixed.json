{
  "realm": "bank",
  "enabled": true,
  "displayName": "Bank Application Realm",
  "displayNameHtml": "<b>Bank Application</b> Realm",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "clientSessionIdleTimeout": 1800,
  "clientSessionMaxLifespan": 36000,
  "refreshTokenMaxReuse": 0,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "defaultSignatureAlgorithm": "RS256",
  "revokeRefreshToken": false,

  "clients": [
    {
      "clientId": "bank-frontend",
      "name": "Bank Frontend UI",
      "description": "Frontend web application for bank users",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/bank-client",
        "http://localhost:8080/*",
        "http://front-ui:8080/login/oauth2/code/bank-client",
        "http://front-ui:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://front-ui:8080"
      ],
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.revoke.offline.tokens": "false",
        "use.refresh.tokens": "true",
        "backchannel.logout.session.required": "true",
        "client_credentials.use_refresh_token": "false",
        "require.pushed.authorization.requests": "false",
        "acr.loa.map": "{}",
        "tls.client.certificate.bound.access.tokens": "false",
        "require.proof.key": "false"
      }
    },
    {
      "clientId": "accounts-service",
      "name": "Accounts Service",
      "description": "Microservice for managing bank accounts",
      "enabled": true,
      "secret": "accounts-secret",
      "redirectUris": [],
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "client_credentials.use_refresh_token": "true"
      }
    },
    {
      "clientId": "cash-service",
      "name": "Cash Service",
      "description": "Microservice for cash deposits and withdrawals",
      "enabled": true,
      "secret": "cash-secret",
      "redirectUris": [],
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "client_credentials.use_refresh_token": "true"
      }
    },
    {
      "clientId": "transfer-service",
      "name": "Transfer Service",
      "description": "Microservice for money transfers between accounts",
      "enabled": true,
      "secret": "transfer-secret",
      "redirectUris": [],
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "client_credentials.use_refresh_token": "true"
      }
    }
  ],

