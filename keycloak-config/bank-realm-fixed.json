  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Regular bank user"
      },
      {
        "name": "admin",
        "description": "Bank administrator"
      }
    ],
    "client": {
      "accounts-service": [
        {
          "name": "view_profile",
          "description": "View user profile"
        },
        {
          "name": "manage_account",
          "description": "Manage user account"
        },
        {
          "name": "view_any_account",
          "description": "View any account (admin)"
        }
      ],
      "cash-service": [
        {
          "name": "view_account",
          "description": "View account balance"
        },
        {
          "name": "execute_cash",
          "description": "Execute cash operations"
        }
      ],
      "transfer-service": [
        {
          "name": "view_account",
          "description": "View account balance"
        },
        {
          "name": "execute_transfer",
          "description": "Execute money transfers"
        }
      ]
    }
  },

  "scopeMappings": [
    {
      "client": "bank-frontend",
      "roles": ["user"]
    }
  ],

  "defaultDefaultClientScopes": ["profile", "email", "roles"],
  "defaultOptionalClientScopes": ["address", "phone", "offline_access"],

  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "DENY",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },

  "smtpServer": {},
  "eventsEnabled": false,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": []
